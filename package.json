{
  "name": "xbank-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "openapi:gen": "openapi-typescript http://localhost:8080/v3/api-docs -o src/api/schema.d.ts",
